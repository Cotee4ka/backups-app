{
  "name": "backups-app",
  "private": true,
  "version": "0.1.0",
  "description": "Collaborative project backups with realtime sync (Windows/macOS clients + Ubuntu VPS server)",
  "packageManager": "pnpm@9.7.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev:server": "pnpm --filter @backups-app/server dev",
    "dev:client": "pnpm --filter @backups-app/client-desktop dev",
    "build:shared": "pnpm --filter @backups-app/shared build",
    "build:server": "pnpm --filter @backups-app/server build",
    "build:client": "pnpm --filter @backups-app/client-desktop build",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  }
}
