{
  "name": "@backups-app/client-desktop",
  "version": "0.3.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "lint": "eslint src electron",
    "dist:win": "pnpm build && electron-builder --win nsis --config.win.signAndEditExecutable=false",
    "dist:mac": "pnpm build && electron-builder --mac dmg",
    "dist:linux": "pnpm build && electron-builder --linux AppImage",
    "dist": "pnpm build && electron-builder"
  },
  "dependencies": {
    "@backups-app/shared": "workspace:*",
    "@kwsites/file-exists": "^1.1.1",
    "@kwsites/promise-deferred": "^1.1.1",
    "@simple-git/args-pathspec": "^1.0.3",
    "@simple-git/argv-parser": "^1.1.0",
    "anymatch": "^3.1.3",
    "asn1": "^0.2.6",
    "auto-launch": "^5.0.6",
    "bcrypt-pbkdf": "^1.0.2",
    "binary-extensions": "^2.3.0",
    "braces": "^3.0.3",
    "chokidar": "^3.6.0",
    "debug": "^4.4.0",
    "ecc-jsbn": "^0.2.0",
    "electron-store": "^10.0.0",
    "fill-range": "^7.1.1",
    "glob-parent": "^5.1.2",
    "has-flag": "^4.0.0",
    "is-binary-path": "^2.1.0",
    "is-extglob": "^2.1.1",
    "is-glob": "^4.0.3",
    "is-number": "^7.0.0",
    "jsbn": "^1.1.0",
    "ms": "^2.1.3",
    "nanoid": "^5.0.7",
    "normalize-path": "^3.0.0",
    "path-is-absolute": "^2.0.0",
    "picomatch": "^2.3.1",
    "readdirp": "^3.6.0",
    "safer-buffer": "^2.1.2",
    "simple-git": "^3.25.0",
    "ssh2": "^1.15.0",
    "streamsearch": "^1.1.0",
    "supports-color": "^7.2.0",
    "to-regex-range": "^5.0.1",
    "tweetnacl": "^1.0.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/auto-launch": "^5.0.5",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2": "^1.15.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "lucide-react": "^0.408.0",
    "postcss": "^8.4.40",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "tailwind-merge": "^2.4.0",
    "tailwindcss": "^3.4.7",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.5.4",
    "vite": "^5.3.5",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "zustand": "^4.5.4"
  },
  "build": {
    "appId": "app.backups.desktop",
    "productName": "Backups App",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../server/scripts/install.sh",
        "to": "install.sh"
      },
      {
        "from": "../server/scripts/install-v2.sh",
        "to": "install-v2.sh"
      },
      {
        "from": "../../package.json",
        "to": "server-source/package.json"
      },
      {
        "from": "../../pnpm-workspace.yaml",
        "to": "server-source/pnpm-workspace.yaml"
      },
      {
        "from": "../../tsconfig.base.json",
        "to": "server-source/tsconfig.base.json"
      },
      {
        "from": "../server/package.json",
        "to": "server-source/apps/server/package.json"
      },
      {
        "from": "../server/tsconfig.json",
        "to": "server-source/apps/server/tsconfig.json"
      },
      {
        "from": "../server/Dockerfile",
        "to": "server-source/apps/server/Dockerfile"
      },
      {
        "from": "../server/.dockerignore",
        "to": "server-source/apps/server/.dockerignore"
      },
      {
        "from": "../server/src",
        "to": "server-source/apps/server/src"
      },
      {
        "from": "../../packages/shared/package.json",
        "to": "server-source/packages/shared/package.json"
      },
      {
        "from": "../../packages/shared/tsconfig.json",
        "to": "server-source/packages/shared/tsconfig.json"
      },
      {
        "from": "../../packages/shared/src",
        "to": "server-source/packages/shared/src"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    }
  }
}
