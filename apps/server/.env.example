# Используется при локальной разработке сервера
BACKUPS_HOST=0.0.0.0
BACKUPS_PORT=8443
BACKUPS_TLS=true
BACKUPS_DATA_DIR=./data

# Если задано, при пустой БД создастся owner с этими кредами:
# BACKUPS_ADMIN_USER=owner
# BACKUPS_ADMIN_PASSWORD=changeme

# Стабильный JWT secret в dev (иначе при перезапуске токены будут невалидны)
BACKUPS_JWT_SECRET=dev-secret-change-me-in-production

# Срок жизни токенов
BACKUPS_ACCESS_TTL=900
BACKUPS_REFRESH_TTL=604800
