{
  "name": "@backups-app/server",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "docker:build": "docker build -t backups-app-server .",
    "docker:up": "docker compose up -d"
  },
  "dependencies": {
    "@backups-app/shared": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "@fastify/static": "^7.0.4",
    "argon2": "^0.40.3",
    "better-sqlite3": "^11.1.2",
    "fastify": "^4.28.1",
    "nanoid": "^5.0.7",
    "node-git-server": "^1.0.0",
    "selfsigned": "^2.4.1",
    "simple-git": "^3.25.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.10",
    "@types/ws": "^8.5.12",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
